digraph ERD {
    // Graph settings
    graph [
        rankdir=LR,
        splines=polyline,
        nodesep=0.8,
        ranksep=1.5,
        fontname="Helvetica",
        fontsize=12,
        label="Spa Management System - Entity Relationship Diagram",
        labelloc=t,
        fontsize=20
    ];
    
    node [
        shape=record,
        fontname="Helvetica",
        fontsize=10,
        style=filled,
        fillcolor="#E3F2FD",
        color="#1976D2"
    ];
    
    edge [
        fontname="Helvetica",
        fontsize=9,
        color="#666666"
    ];

    // User model (Django built-in)
    User [
        label="{User|+ id : PK\l+ username : VARCHAR(150)\l+ email : VARCHAR(254)\l+ first_name : VARCHAR(150)\l+ last_name : VARCHAR(150)\l+ is_staff : BOOLEAN\l+ is_active : BOOLEAN\l+ date_joined : DATETIME\l}",
        fillcolor="#FFF3E0"
    ];

    // Service model
    Service [
        label="{Service|+ id : PK\l+ code : VARCHAR(20) UNIQUE\l+ name : VARCHAR(200)\l+ slug : VARCHAR(250) UNIQUE\l+ category : VARCHAR(20)\l+ short_description : VARCHAR(300)\l+ description : TEXT\l+ price : DECIMAL(10,0)\l+ duration_minutes : INT\l+ status : VARCHAR(20)\l+ image : VARCHAR(100)\l+ is_active : BOOLEAN\l+ created_by_id : FK → User\l+ updated_by_id : FK → User\l+ created_at : DATETIME\l+ updated_at : DATETIME\l}",
        fillcolor="#E8F5E9"
    ];

    // CustomerProfile model
    CustomerProfile [
        label="{CustomerProfile|+ id : PK\l+ user_id : FK → User (1:1)\l+ phone : VARCHAR(20) UNIQUE\l+ full_name : VARCHAR(200)\l+ gender : CHAR(1)\l+ dob : DATE\l+ address : TEXT\l+ notes : TEXT\l+ created_at : DATETIME\l+ updated_at : DATETIME\l}",
        fillcolor="#FCE4EC"
    ];

    // Room model
    Room [
        label="{Room|+ id : PK\l+ code : VARCHAR(10) UNIQUE\l+ name : VARCHAR(50)\l+ capacity : INT\l+ is_active : BOOLEAN\l+ created_at : DATETIME\l+ updated_at : DATETIME\l}",
        fillcolor="#F3E5F5"
    ];

    // Appointment model
    Appointment [
        label="{Appointment|+ id : PK\l+ appointment_code : VARCHAR(20) UNIQUE\l+ customer_id : FK → CustomerProfile\l+ service_id : FK → Service\l+ room_id : FK → Room\l+ appointment_date : DATE\l+ appointment_time : TIME\l+ end_time : TIME\l+ duration_minutes : INT\l+ guests : INT\l+ status : VARCHAR(20)\l+ payment_status : VARCHAR(20)\l+ source : VARCHAR(10)\l+ notes : TEXT\l+ staff_notes : TEXT\l+ created_by_id : FK → User\l+ created_at : DATETIME\l+ updated_at : DATETIME\l}",
        fillcolor="#E0F7FA"
    ];

    // Complaint model
    Complaint [
        label="{Complaint|+ id : PK\l+ code : VARCHAR(20) UNIQUE\l+ customer_id : FK → CustomerProfile\l+ full_name : VARCHAR(200)\l+ phone : VARCHAR(20)\l+ email : VARCHAR(254)\l+ title : VARCHAR(200)\l+ content : TEXT\l+ complaint_type : VARCHAR(20)\l+ priority : VARCHAR(20)\l+ incident_date : DATE\l+ appointment_code : VARCHAR(20)\l+ related_service_id : FK → Service\l+ expected_solution : TEXT\l+ status : VARCHAR(20)\l+ assigned_to_id : FK → User\l+ resolution : TEXT\l+ resolved_at : DATETIME\l+ created_at : DATETIME\l+ updated_at : DATETIME\l}",
        fillcolor="#FFF8E1"
    ];

    // ComplaintReply model
    ComplaintReply [
        label="{ComplaintReply|+ id : PK\l+ complaint_id : FK → Complaint\l+ sender_id : FK → User\l+ sender_role : VARCHAR(20)\l+ sender_name : VARCHAR(200)\l+ message : TEXT\l+ is_internal : BOOLEAN\l+ created_at : DATETIME\l}",
        fillcolor="#FFEBEE"
    ];

    // ComplaintHistory model
    ComplaintHistory [
        label="{ComplaintHistory|+ id : PK\l+ complaint_id : FK → Complaint\l+ action : VARCHAR(30)\l+ old_value : VARCHAR(200)\l+ new_value : VARCHAR(200)\l+ note : TEXT\l+ performed_by_id : FK → User\l+ performed_at : DATETIME\l}",
        fillcolor="#F1F8E9"
    ];

    // Relationships
    
    // User -> CustomerProfile (One-to-One)
    User -> CustomerProfile [
        xlabel="1:1",
        headlabel="1",
        taillabel="1",
        style=bold,
        color="#E91E63"
    ];

    // User -> Service (One-to-Many - created_by)
    User -> Service [
        xlabel="creates",
        headlabel="N",
        taillabel="1",
        style=dashed,
        color="#4CAF50"
    ];
    
    // User -> Service (One-to-Many - updated_by)
    User -> Service [
        xlabel="updates",
        headlabel="N",
        taillabel="1",
        style=dotted,
        color="#4CAF50"
    ];

    // CustomerProfile -> Appointment (One-to-Many)
    CustomerProfile -> Appointment [
        xlabel="has",
        headlabel="N",
        taillabel="1",
        color="#009688"
    ];

    // Service -> Appointment (One-to-Many)
    Service -> Appointment [
        xlabel="booked in",
        headlabel="N",
        taillabel="1",
        color="#2196F3"
    ];

    // Room -> Appointment (One-to-Many)
    Room -> Appointment [
        xlabel="hosts",
        headlabel="N",
        taillabel="1",
        style=dashed,
        color="#9C27B0"
    ];

    // User -> Appointment (One-to-Many - created_by)
    User -> Appointment [
        xlabel="creates",
        headlabel="N",
        taillabel="1",
        style=dashed,
        color="#FF9800"
    ];

    // CustomerProfile -> Complaint (One-to-Many)
    CustomerProfile -> Complaint [
        xlabel="submits",
        headlabel="N",
        taillabel="1",
        style=dashed,
        color="#F44336"
    ];

    // Service -> Complaint (One-to-Many - related_service)
    Service -> Complaint [
        xlabel="related to",
        headlabel="N",
        taillabel="1",
        style=dashed,
        color="#3F51B5"
    ];

    // User -> Complaint (One-to-Many - assigned_to)
    User -> Complaint [
        xlabel="assigned to",
        headlabel="N",
        taillabel="1",
        style=dashed,
        color="#795548"
    ];

    // Complaint -> ComplaintReply (One-to-Many)
    Complaint -> ComplaintReply [
        xlabel="has",
        headlabel="N",
        taillabel="1",
        color="#607D8B"
    ];

    // User -> ComplaintReply (One-to-Many - sender)
    User -> ComplaintReply [
        xlabel="sends",
        headlabel="N",
        taillabel="1",
        style=dashed,
        color="#00BCD4"
    ];

    // Complaint -> ComplaintHistory (One-to-Many)
    Complaint -> ComplaintHistory [
        xlabel="tracks",
        headlabel="N",
        taillabel="1",
        color="#8BC34A"
    ];

    // User -> ComplaintHistory (One-to-Many - performed_by)
    User -> ComplaintHistory [
        xlabel="performs",
        headlabel="N",
        taillabel="1",
        style=dashed,
        color="#CDDC39"
    ];

    // Legend
    subgraph cluster_legend {
        label="Legend";
        style=dashed;
        color="#999999";
        fontsize=11;
        
        legend_node [
            shape=record,
            label="{Relationship Types|\l━━━  One-to-Many (Required)\l- - -  One-to-Many (Optional)\l━━━  One-to-One\l}",
            fillcolor="#FAFAFA"
        ];
    }
}